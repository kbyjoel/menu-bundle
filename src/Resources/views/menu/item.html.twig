<li class="li-movable"
    data-type="{% if item is defined %}{% if item.link %}link{% elseif item.page or item.staticPage %}page{% elseif item.title %}section{% else %}{{ item.type }}{% endif %}{% endif %}"
    data-payload="{{ item is defined and menuManager is defined ? menuManager.getPayload(item)|json_encode : '{}' }}"
    data-title="{{ item is defined ? item.title : '' }}"
    data-original-title="{{ item is defined ? item.originalTitle : '' }}"
    data-required="{{ item is defined and item.isRequired ? '1' : '0' }}">
    <div class="dd-handle">
        <div>
            <div class="text-semibold title">{{ item is defined ? item.title : '' }}</div>
            {% if item is defined and item.link %}
                <div class="text-muted link"><a href="{{ item.link }}" target="_blank">{{ item.linkDomain }}</a></div>
            {% elseif item is defined and item.originalTitle %}
                <div class="text-muted link">{{ item.originalTitle }}</div>
            {% else %}
                <div class="text-muted link">&nbsp;</div>
            {% endif %}
        </div>
        <div class="cell-menu" style="width:80px">
            <ul class="icons-list">
                <li class="dropdown">
                    <a href="#" class="dropdown-toggle" data-bs-toggle="dropdown"><i class="fas fa-bars"></i></a>
                    <div class="dropdown-menu dropdown-menu-right">
                        <a class="dropdown-item cursor-pointer" data-action="click->aropixel-menu#openEditModal"><i class="fas fa-edit me-2"></i> {% trans %}aropixel.menu.form.edit{% endtrans %}</a>
                        <a class="dropdown-item cursor-pointer text-danger" data-action="click->aropixel-menu#deleteRow"><i class="fas fa-trash me-2"></i> {% trans %}aropixel.menu.form.delete{% endtrans %}</a>
                    </div>
                </li>
            </ul>
        </div>
        <div class="cell-label">
            {% if item is defined %}
                {% if item.link %}
                    <span class="badge bg-teal">{% trans %}aropixel.menu.form.type.link{% endtrans %}</span>
                {% elseif item.page or item.staticPage %}
                    <span class="badge bg-pink">{% trans %}aropixel.menu.form.type.page{% endtrans %}</span>
                {% elseif item.title %}
                    <span class="badge bg-dark-grey">{% trans %}aropixel.menu.form.type.section{% endtrans %}</span>
                {% endif %}
            {% endif %}
        </div>
    </div>

    {% if item is defined %}
        {% if item.children is not empty %}
            <ol>
                {% for sbitem in item.children %}
                    {{ include('@AropixelMenu/menu/item.html.twig', {'item': sbitem, 'menuManager': menuManager}) }}
                {% endfor %}
            </ol>
        {% endif %}
    {% endif %}
</li>
